# Plantilla de variables de entorno para StreamFlix.
# Copia este archivo como ".env" y rellena con tus valores de Supabase.
# (El archivo .env NO se sube al repositorio — está en .gitignore.)
#
# Dónde obtenerlas:  Supabase → Project Settings → API
#   - SUPABASE_URL       = "Project URL"            (https://xxxx.supabase.co)
#   - SUPABASE_ANON_KEY  = "Project API keys" → anon public  (token eyJ...)

SUPABASE_URL=
SUPABASE_ANON_KEY=
